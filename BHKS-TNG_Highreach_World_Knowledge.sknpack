      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingElenwenWritSigned\") == 1 and is_in_faction(actorUUID, \"ThalmorFaction\")",
        "content": "The crown has signed an official writ against First Emissary Elenwen and the Thalmor presence in Skyrim. This is a direct challenge to the Aldmeri Dominion's authority. Thalmor agents and Justiciars are aware that the political winds have shifted against them and their operations in Skyrim are now under formal threat from the throne.",
        "display_name": "Elenwen Writ Signed - Thalmor Awareness",
        "emotion": "",
        "importance": 0.8,
        "location": "Skyrim",
        "tags": [
          "thalmor",
          "elenwen",
          "writ",
          "dominion",
          "politics",
          "threat"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingElenwenWritSigned\") == 1 and is_in_faction(actorUUID, \"JobJarlFaction\")",
        "content": "The crown has taken a formal stance against the Thalmor by signing an official writ targeting First Emissary Elenwen. The Jarls of Skyrim are aware of this bold political move. Some see it as long-overdue defiance of the Aldmeri Dominion, while others worry it may provoke dangerous retaliation. The White-Gold Concordat's enforcement in Skyrim hangs in the balance.",
        "display_name": "Elenwen Writ Signed - Jarl Awareness",
        "emotion": "",
        "importance": 0.75,
        "location": "Skyrim",
        "tags": [
          "thalmor",
          "elenwen",
          "writ",
          "jarls",
          "politics",
          "concordat"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingElenwenWritSigned\") == 1 and is_in_faction(actorUUID, \"AAHighKingCouncilFaction\")",
        "content": "The royal council is aware that the crown has signed an official writ against First Emissary Elenwen and the Thalmor. This escalation has significant diplomatic and military implications. The council must prepare for potential Thalmor retaliation and consider how this affects Skyrim's relationships with the Empire and the Aldmeri Dominion.",
        "display_name": "Elenwen Writ Signed - Council Awareness",
        "emotion": "",
        "importance": 0.75,
        "location": "Skyrim",
        "tags": [
          "thalmor",
          "elenwen",
          "writ",
          "council",
          "strategy",
          "diplomacy"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingElenwenKilledVoC\") == 1 and is_in_faction(actorUUID, \"ThalmorFaction\")",
        "content": "First Emissary Elenwen is dead, killed during a mission carried out by the Voice of the Crown. The most powerful Thalmor representative in Skyrim was slain. This is an act of war in all but name. The Aldmeri Dominion will not forget or forgive this. Thalmor agents remaining in Skyrim operate in fear, knowing the crown has the will and the means to strike at even their highest-ranking officials.",
        "display_name": "Elenwen Killed - Thalmor Awareness",
        "emotion": "",
        "importance": 0.85,
        "location": "Skyrim",
        "tags": [
          "thalmor",
          "elenwen",
          "killed",
          "dominion",
          "war",
          "voice of the crown"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingElenwenKilledVoC\") == 1 and (is_in_faction(actorUUID, \"JobJarlFaction\") or is_in_faction(actorUUID, \"AAHighKingCouncilFaction\"))",
        "content": "First Emissary Elenwen is dead, killed during a Voice of the Crown operation. The Jarls and royal council know this changes everything. The Thalmor will demand answers or retribution. Some Jarls who chafed under Thalmor oversight celebrate quietly, while others fear the diplomatic fallout. Skyrim has drawn a line in blood that cannot be undrawn.",
        "display_name": "Elenwen Killed - Jarl and Council Awareness",
        "emotion": "",
        "importance": 0.8,
        "location": "Skyrim",
        "tags": [
          "thalmor",
          "elenwen",
          "killed",
          "jarls",
          "council",
          "consequences"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingLoanOverdueCount\") >= 2 and is_in_faction(actorUUID, \"JobMerchantFaction\")",
        "content": "The crown has fallen behind on loan repayments. Creditors are growing impatient and the ruler's financial reputation is suffering. If payments continue to be missed, the crown risks losing property seized as collateral. Word of the crown's debts has begun to spread among merchants and nobles.",
        "display_name": "Kingdom Loan - Payments Overdue",
        "emotion": "",
        "importance": 0.65,
        "location": "Skyrim",
        "tags": [
          "loan",
          "debt",
          "overdue",
          "treasury",
          "financial crisis"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingLoanSeized\") == 1",
        "content": "Creditors have seized the crown's property as collateral for unpaid debts. The ruler's homes have been locked and foreclosure notices posted. This is a devastating blow to royal prestige - a ruler who cannot pay their debts is a ruler whose authority is crumbling.",
        "display_name": "Kingdom Loan - Property Seized",
        "emotion": "",
        "importance": 0.75,
        "location": "Skyrim",
        "tags": [
          "loan",
          "foreclosure",
          "seized",
          "debt",
          "prestige",
          "crisis"
        ],
        "type": "KNOWLEDGE"
      },
      {
        "always_inject": false,
        "condition_expr": "get_global_value(\"AAIsHighKing\") == 1 and get_global_value(\"AAKingMavenSentenced\") == 1 and is_in_faction(actorUUID, \"CrimeFactionRift\")",
        "content": "Maven Black-Briar, the most powerful and feared woman in Riften, has been tried and sentenced by the crown. Her downfall has sent shockwaves through The Rift. Some celebrate the end of her corrupt influence, while others fear what will fill the power vacuum she leaves behind.",
        "display_name": "Maven Black-Briar Sentenced",
        "emotion": "",
        "importance": 0.6,
        "location": "The Rift",
        "tags": [
          "maven",
          "trial",
          "sentenced",
          "riften",
          "justice",
          "politics"
        ],
        "type": "KNOWLEDGE"
      }
